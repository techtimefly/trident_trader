# Copy to .env and fill in. Never commit .env.
# Every key here can equivalently be set as a real environment variable;
# exported env vars take precedence over this file, so .env is optional.
# IMPORTANT: dotenv does not strip inline comments after values reliably,
# so keep comments on their own lines.

# Alpaca paper-trading credentials.
# Sign up at https://alpaca.markets, then in the dashboard:
#   1. Switch to "Paper Trading" (top-right toggle).
#   2. Click "View / Generate API Keys" in the right panel.
#   3. Paste the Key ID and Secret below.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Data feed: "iex" (free with paper account) or "sip" (paid).
ALPACA_DATA_FEED=iex

# Financial Modeling Prep API key — optional. Enables the screener's fast
# server-side universe pre-filter (market cap / sector / exchange). When blank,
# the screener falls back to the alphabetical Alpaca universe.
# Get a free key at https://site.financialmodelingprep.com (250 requests/day).
FMP_API_KEY=

# Postgres. Defaults match docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://trident:trident@localhost:5432/trident

# Risk parameters (overridable here, defaults live in src/trident/risk/limits.py).
RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_PCT=2.0
MAX_CONCURRENT_POSITIONS=3

# Optional: pin the account equity used for sizing. Leave blank to read from Alpaca.
ACCOUNT_EQUITY_OVERRIDE=

# Honest-backtest cost model (scripts/backtest.py). Slippage is synthetic basis
# points (the IEX feed has no bid/ask); fees default to realistic small values.
# CLI flags on backtest.py override these.
BACKTEST_SLIPPAGE_BPS=2.0
BACKTEST_FEE_PER_SHARE=0
BACKTEST_MIN_FEE=0
BACKTEST_SEC_FEE_RATE=0.0000278
BACKTEST_TAF_PER_SHARE=0.000166

# Operational. ENVIRONMENT is one of: development | paper | live.
LOG_LEVEL=INFO
LOG_DIR=./logs
ENVIRONMENT=development
