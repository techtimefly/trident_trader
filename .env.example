# Copy to .env and fill in. Never commit .env.

# Alpaca paper-trading credentials.
# Sign up at https://alpaca.markets, then in the dashboard:
#   1. Switch to "Paper Trading" (top-right toggle).
#   2. Click "View / Generate API Keys" in the right panel.
#   3. Paste the Key ID and Secret below.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex  # iex (free) or sip (paid)

# Postgres. Defaults match docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://trident:trident@localhost:5432/trident

# Risk parameters (overridable here, defaults live in config/default.yml).
RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_PCT=2.0
MAX_CONCURRENT_POSITIONS=3
ACCOUNT_EQUITY_OVERRIDE=  # leave blank to read from Alpaca

# Operational.
LOG_LEVEL=INFO
LOG_DIR=./logs
ENVIRONMENT=development  # development | paper | live
